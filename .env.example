# Required: completion proxy URL (routes to Anthropic)
COMPLETION_PROXY_URL=http://127.0.0.1:9878
AISHA_MODEL=claude-sonnet-4-5

# Slack (optional)
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# Twilio / WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_DEFAULT_TO=
WHATSAPP_LISTENER_PORT=9879
WHATSAPP_PUBLIC_URL=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs. Leave blank to accept all chats.
TELEGRAM_ALLOWED_CHAT_IDS=

# Behavior
AISHA_LOG_LEVEL=INFO
AISHA_MAX_CONTEXT_TURNS=40
AISHA_EMBEDDING_MODEL=all-MiniLM-L6-v2
