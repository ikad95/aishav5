# === Pick ONE: direct API key, or a proxy URL ===

# Simplest: Anthropic API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Alternative: route through a local proxy that handles auth, caching, etc.
# COMPLETION_PROXY_URL=http://127.0.0.1:9878

# Model (defaults to claude-sonnet-4-6)
AISHA_MODEL=claude-sonnet-4-6

# === Channels (all optional) ===

# Slack Socket Mode — https://api.slack.com/apps
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# WhatsApp via Twilio — https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_DEFAULT_TO=
WHATSAPP_LISTENER_PORT=9879
WHATSAPP_PUBLIC_URL=

# Telegram Bot — talk to @BotFather to get a token
TELEGRAM_BOT_TOKEN=
# Optional: comma-separated chat IDs. Leave blank to accept all chats.
TELEGRAM_ALLOWED_CHAT_IDS=

# === Behavior ===

AISHA_LOG_LEVEL=INFO
AISHA_MAX_CONTEXT_TURNS=40
AISHA_EMBEDDING_MODEL=all-MiniLM-L6-v2
